<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.OCRjizhang" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_brand</item>
        <item name="colorOnPrimary">@color/surface_container</item>
        <item name="colorPrimaryContainer">@color/surface_tint_soft</item>
        <item name="colorSecondary">@color/secondary_brand</item>
        <item name="colorSurface">@color/surface_base</item>
        <item name="colorSurfaceContainer">@color/surface_container</item>
        <item name="colorOutline">@color/outline_soft</item>
        <item name="android:statusBarColor">@color/surface_base</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/surface_container</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.OCRjizhang" parent="Base.Theme.OCRjizhang" />

    <style name="Widget.OCRjizhang.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/surface_tint_soft</item>
    </style>

    <style name="ThemeOverlay.OCRjizhang.TransactionEntryBottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.OCRjizhang.TransactionEntryBottomSheet</item>
        <item name="android:windowIsFloating">false</item>
        <item name="enableEdgeToEdge">true</item>
    </style>

    <style name="Widget.OCRjizhang.TransactionEntryBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.None</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.OCRjizhang.SheetTopOnly" parent="">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerFamilyBottomRight">rounded</item>
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.OCRjizhang.PanelTopOnly" parent="">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerFamilyBottomRight">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
